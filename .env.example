# ArangoDB connection
ARANGO_HOST=https://your-arango-host
ARANGO_DB=ingest_bench_db
ARANGO_USERNAME=root
ARANGO_PASSWORD=change-me

# Collection names (override only if your dataset differs)
ARANGO_SIMILARITY_COLLECTION=multihop_eval_similarities
ARANGO_RELATIONS_COLLECTION=multihop_eval_corpus_relations
ARANGO_RAGS_COLLECTION=multihop_eval_rags
ARANGO_SOURCES_COLLECTION=multihop_eval_sources
ARANGO_DOMAINS_COLLECTION=multihop_eval_domains
ARANGO_QA_COLLECTION=qa_pairs_multihop_eval_v1

# LLM (OpenAI-compatible Chat Completions)
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-4.1
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_S=180
LLM_RETRIES=3
LLM_BACKOFF_BASE=2

# Logging
LOG_LEVEL=INFO
